{
    "workbench.colorTheme": "Quiet Light",
    "workbench.tips.enabled": false,
    "extensions.ignoreRecommendations": true,
    "editor.minimap.enabled": false,
    "workbench.editor.enablePreview": false,
    "git.confirmSync": false,

    "emeraldwalk.runonsave": {
        
        "commands": [
            { "match": "\\.c$",   "cmd": "zig cc ${file}" },
            { "match": "\\.rs$",  "cmd": "cd ${fileDirname}/.. && cargo run" },
            { "match": "\\.java$","cmd": "java ${file}" },
            { "match": "\\.jsh$", "cmd": "jshell ${file} --show-version --execution local" },
            { "match": "\\.cpp$", "cmd": "g++ -std=c++17 -pthread -lpthread ${file} && ./a.out" },
            {
                "match": "\\.go$",
                "cmd": "echo ' ' && date && go run ${file}"
            },
            {
                "match": "\\.py$",
                "cmd": "echo ' ' && date && ~/anaconda3/bin/python3 ${file}"
            }
        ]
    },
    "security.workspace.trust.untrustedFiles": "open"
}

